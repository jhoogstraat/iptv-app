#!/bin/zsh
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
LOCK_FILE="$ROOT_DIR/ThirdParty/vlckit.lock"
CURL_BIN="/usr/bin/curl"
SHA_BIN="/usr/bin/shasum"
AWK_BIN="/usr/bin/awk"
TAR_BIN="/usr/bin/tar"

if [[ ! -f "$LOCK_FILE" ]]; then
  echo "Missing lock file: $LOCK_FILE" >&2
  exit 1
fi

source "$LOCK_FILE"

CACHE_DIR="$ROOT_DIR/Vendor/VLCKit/cache"
FRAMEWORK_DIR="$ROOT_DIR/Vendor/VLCKit/VLCKit.xcframework"
ARCHIVE_PATH="$CACHE_DIR/$VLCKIT_ARCHIVE"
TMP_DIR=""
cleanup() {
  if [[ -n "$TMP_DIR" ]]; then
    rm -rf "$TMP_DIR"
  fi
}
trap cleanup EXIT


mkdir -p "$CACHE_DIR"

download() {
  local actual=""

  if [[ -f "$ARCHIVE_PATH" ]]; then
    actual="$("$SHA_BIN" -a 256 "$ARCHIVE_PATH" | "$AWK_BIN" '{print $1}')"
    if [[ "$actual" == "$VLCKIT_SHA256" ]]; then
      echo "Using cached $VLCKIT_ARCHIVE"
      return
    fi
  fi

  echo "Downloading $VLCKIT_ARCHIVE"
  "$CURL_BIN" -fL -o "$ARCHIVE_PATH" "$VLCKIT_URL"
}

verify_sha() {
  local actual

  actual="$("$SHA_BIN" -a 256 "$ARCHIVE_PATH" | "$AWK_BIN" '{print $1}')"
  if [[ "$actual" != "$VLCKIT_SHA256" ]]; then
    echo "Checksum mismatch for $VLCKIT_ARCHIVE" >&2
    echo "Expected: $VLCKIT_SHA256" >&2
    echo "Actual:   $actual" >&2
    exit 1
  fi
}

extract_xcframework() {
  TMP_DIR="$(mktemp -d "$ROOT_DIR/Vendor/VLCKit/.extract.XXXXXX")"

  rm -rf \
    "$FRAMEWORK_DIR" \
    "$ROOT_DIR/Vendor/VLCKit/iOS" \
    "$ROOT_DIR/Vendor/VLCKit/macOS" \
    "$ROOT_DIR/Vendor/VLCKit/tvOS"

  "$TAR_BIN" -xf "$ARCHIVE_PATH" -C "$TMP_DIR" "$VLCKIT_ROOT/VLCKit.xcframework"
  mv "$TMP_DIR/$VLCKIT_ROOT/VLCKit.xcframework" "$FRAMEWORK_DIR"
}

download
verify_sha
extract_xcframework

echo "VLCKit artifact is available at $FRAMEWORK_DIR"
