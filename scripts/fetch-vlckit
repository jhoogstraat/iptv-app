#!/bin/zsh
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
LOCK_FILE="$ROOT_DIR/ThirdParty/vlckit.lock"
CURL_BIN="/usr/bin/curl"
SHA_BIN="/usr/bin/shasum"
AWK_BIN="/usr/bin/awk"
TAR_BIN="/usr/bin/tar"

if [[ ! -f "$LOCK_FILE" ]]; then
  echo "Missing lock file: $LOCK_FILE" >&2
  exit 1
fi

source "$LOCK_FILE"

mkdir -p \
  "$ROOT_DIR/Vendor/VLCKit/cache" \
  "$ROOT_DIR/Vendor/VLCKit/iOS" \
  "$ROOT_DIR/Vendor/VLCKit/macOS" \
  "$ROOT_DIR/Vendor/VLCKit/tvOS"

download() {
  local url="$1"
  local archive="$2"
  local expected="$3"
  local destination="$ROOT_DIR/Vendor/VLCKit/cache/$archive"
  local actual=""

  if [[ -f "$destination" ]]; then
    actual="$("$SHA_BIN" -a 256 "$destination" | "$AWK_BIN" '{print $1}')"
    if [[ "$actual" == "$expected" ]]; then
      echo "Using cached $archive"
      return
    fi
  fi

  echo "Downloading $archive"
  "$CURL_BIN" -fL -o "$destination" "$url"
}

verify_sha() {
  local archive="$1"
  local expected="$2"
  local path="$ROOT_DIR/Vendor/VLCKit/cache/$archive"
  local actual

  actual="$("$SHA_BIN" -a 256 "$path" | "$AWK_BIN" '{print $1}')"
  if [[ "$actual" != "$expected" ]]; then
    echo "Checksum mismatch for $archive" >&2
    echo "Expected: $expected" >&2
    echo "Actual:   $actual" >&2
    exit 1
  fi
}

extract_xcframework() {
  local archive="$1"
  local root="$2"
  local destination="$3"

  rm -rf "$destination"
  mkdir -p "$destination"
  "$TAR_BIN" -xf "$ROOT_DIR/Vendor/VLCKit/cache/$archive" -C "$destination" --strip-components=1 "$root/VLCKit.xcframework"
}

download "$VLCKIT_IOS_URL" "$VLCKIT_IOS_ARCHIVE" "$VLCKIT_IOS_SHA256"
download "$VLCKIT_MACOS_URL" "$VLCKIT_MACOS_ARCHIVE" "$VLCKIT_MACOS_SHA256"
download "$VLCKIT_TVOS_URL" "$VLCKIT_TVOS_ARCHIVE" "$VLCKIT_TVOS_SHA256"

verify_sha "$VLCKIT_IOS_ARCHIVE" "$VLCKIT_IOS_SHA256"
verify_sha "$VLCKIT_MACOS_ARCHIVE" "$VLCKIT_MACOS_SHA256"
verify_sha "$VLCKIT_TVOS_ARCHIVE" "$VLCKIT_TVOS_SHA256"

extract_xcframework "$VLCKIT_IOS_ARCHIVE" "$VLCKIT_IOS_ROOT" "$ROOT_DIR/Vendor/VLCKit/iOS"
extract_xcframework "$VLCKIT_MACOS_ARCHIVE" "$VLCKIT_MACOS_ROOT" "$ROOT_DIR/Vendor/VLCKit/macOS"
extract_xcframework "$VLCKIT_TVOS_ARCHIVE" "$VLCKIT_TVOS_ROOT" "$ROOT_DIR/Vendor/VLCKit/tvOS"

echo "VLCKit artifacts are available under $ROOT_DIR/Vendor/VLCKit"
